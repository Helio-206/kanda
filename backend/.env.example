# Database
DATABASE_URL=postgres://cidade_user:cidade_pass@db:5432/cidade_em_foco

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Cloudinary (required for POST /occurrences/upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Grounding DINO — local inference via transformers (Celery worker)
GROUNDING_DINO_MODEL_ID=IDEA-Research/grounding-dino-tiny
GROUNDING_DINO_DEVICE=cuda
GROUNDING_DINO_BOX_THRESHOLD=0.4
GROUNDING_DINO_TEXT_THRESHOLD=0.3
# HF_TOKEN=  # optional: faster Hub downloads

SECRET_KEY=change-me
